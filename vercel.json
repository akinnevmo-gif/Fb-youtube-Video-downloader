{
  "buildCommand": "npm install --prefix artifacts/social-hk && npm run build --prefix artifacts/social-hk",
  "outputDirectory": "artifacts/social-hk/dist/public",
  "installCommand": "echo 'skip'",
  "framework": null,
  "env": {
    "PORT": "3000",
    "BASE_PATH": "/"
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
